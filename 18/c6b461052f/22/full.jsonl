_created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    _updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n\n\nCREATE TRIGGER trigger_courses_meta_updated_at\n    BEFORE UPDATE ON courses\n    FOR EACH ROW\n    EXECUTE FUNCTION update_meta_updated_at();\n\nCREATE TRIGGER trigger_categories_meta_updated_at\n    BEFORE UPDATE ON categories\n    FOR EACH ROW\n    EXECUTE FUNCTION update_meta_updated_at();\n\nCREATE TRIGGER trigger_authors_meta_updated_at\n    BEFORE UPDATE ON authors\n    FOR EACH ROW\n    EXECUTE FUNCTION update_meta_updated_at();\n\nCOMMENT ON COLUMN courses.publish_status IS 'draft / published / archived';\n","numLines":63,"startLine":1,"totalLines":63}},"sourceToolAssistantUUID":"e7a405c9-c7d6-476c-9b89-de71bb9322d5","userType":"external","entrypoint":"cli","cwd":"/Users/haru/ghq/github.com/harusame0616/ijuku","sessionId":"e12924b4-54c6-4d4a-a50f-201caa3601ca","version":"2.1.81","gitBranch":"main","slug":"glowing-painting-avalanche"}
